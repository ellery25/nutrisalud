# Copy to .env for local development. NEVER commit .env.

# development | testing | production
FLASK_ENV=development

# REQUIRED in production — generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=
JWT_SECRET_KEY=

# postgresql://user:pass@host:5432/nutrisalud  (sqlite used by default in development)
DATABASE_URL=

# Comma-separated allowed origins, e.g. https://nutrisalud.app
CORS_ORIGINS=*

# Optional: enables shared rate-limit storage and Celery broker
REDIS_URL=

LOG_LEVEL=INFO
